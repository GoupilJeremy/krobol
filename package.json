{
  "name": "krobol",
  "displayName": "Krobol IDE",
  "description": "A futuristic IDE for Krobol, a condensed COBOL language with automated retro-documentation.",
  "version": "0.1.0",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages", "Testing"],
  "activationEvents": [
    "onCommand:krobol.transpileKrobolToCobol",
    "onCommand:krobol.transpileCobolToKrobol",
    "onCommand:krobol.generateDocumentation"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "vscode": "^1.75.0",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.75.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "krobol.transpileKrobolToCobol",
        "title": "Krobol: Transpiler en COBOL"
      },
      {
        "command": "krobol.transpileCobolToKrobol",
        "title": "Krobol: Transpiler en Krobol"
      },
      {
        "command": "krobol.generateDocumentation",
        "title": "Krobol: Générer la documentation"
      }
    ]
  }
}